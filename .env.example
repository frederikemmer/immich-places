# URL of your Immich instance (internal/docker network)
IMMICH_URL=http://localhost:2283

# Optional: public-facing Immich URL if different from IMMICH_URL
# IMMICH_EXTERNAL_URL=https://photos.example.com

# Directory where the SQLite database is stored
DATA_DIR=./data

# Port the backend listens on
PORT=8082

# How often to sync with Immich (in milliseconds, default: 5 minutes)
SYNC_INTERVAL_MS=300000

# Set to true when running behind a reverse proxy that terminates TLS (marks session cookies as Secure)
TRUST_PROXY_TLS=true

# Set to true for local development over plain HTTP (disables Secure flag on cookies)
# ALLOW_INSECURE=true

# Set to false to prevent new user registrations
REGISTRATION_ENABLED=true

# Secret used to encrypt Immich API keys at rest (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=change-me-to-a-random-secret

# Geocode provider (only 'nominatim' supported for now)
# GEOCODE_PROVIDER=nominatim

# API key for geocode provider (reserved for future use)
# GEOCODE_API_KEY=

# Base URL for the Nominatim instance (override for self-hosted)
# GEOCODE_URL=https://nominatim.openstreetmap.org

# Upstream geocode request timeout in seconds (default: 10)
# GEOCODE_TIMEOUT=10
